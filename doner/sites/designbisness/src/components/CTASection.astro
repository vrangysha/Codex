---
import { ArrowRight } from "@lucide/astro";

interface Props {
  title: string;
  text: string;
  image: string;
  imageAlt: string;
  href?: string;
  label?: string;
}

const { title, text, image, imageAlt, href = "/brief/", label = "Оставить заявку" } = Astro.props;
---

<section class="cta-section">
  <div class="cta-image">
    <img src={image} alt={imageAlt} loading="lazy" decoding="async" />
  </div>
  <div class="cta-copy">
    <p class="section-label">Готовы начать проект?</p>
    <h2>{title}</h2>
    <p>{text}</p>
    <a class="button button-dark" href={href}>
      {label}
      <ArrowRight size={17} stroke-width={1.5} />
    </a>
  </div>
</section>
