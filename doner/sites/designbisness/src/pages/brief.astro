---
import { Clock3, Lock, CloudUpload } from "@lucide/astro";
import HeroSplit from "@components/HeroSplit.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { asset } from "@data/site";
---

<BaseLayout
  title="Бриф на дизайн-проект — AURUM"
  description="Подробная форма брифа AURUM для старта дизайн-проекта: контакты, объект, стиль, бюджет, материалы, помещения и референсы."
>
  <HeroSplit
    eyebrow="Хороший дизайн начинается с правильных вопросов"
    title="Бриф на дизайн-проект"
    text="Расскажите о себе, вашем пространстве и пожеланиях. Мы внимательно изучим бриф и предложим лучшее решение для будущего интерьера."
    image={asset.hero}
    imageAlt="Светлая гостиная с диваном, столиком и растениями"
    primaryHref="#brief-form"
    primaryLabel="Заполнить бриф"
    secondaryHref="/quiz/"
    secondaryLabel="Пройти квиз по стилю"
  />

  <section class="section">
    <div class="brief-layout">
      <form class="brief-form" id="brief-form" data-brief-form novalidate>
        <section class="form-section" aria-labelledby="contacts">
          <h2 id="contacts">1. Контактные данные</h2>
          <div class="form-grid">
            <label class="field">
              <span>Ваше имя*</span>
              <input required name="name" placeholder="Как к вам обращаться?" />
            </label>
            <label class="field">
              <span>Телефон*</span>
              <input required name="phone" type="tel" placeholder="+7 (___) ___-__-__" />
            </label>
            <label class="field">
              <span>E-mail*</span>
              <input required name="email" type="email" placeholder="example@mail.ru" />
            </label>
            <label class="field">
              <span>Удобный способ связи</span>
              <select name="channel">
                <option>Telegram</option>
                <option>WhatsApp</option>
                <option>Телефон</option>
                <option>E-mail</option>
              </select>
            </label>
          </div>
        </section>

        <section class="form-section" aria-labelledby="object">
          <h2 id="object">2. Информация об объекте</h2>
          <div class="form-grid">
            <label class="field">
              <span>Тип объекта*</span>
              <select required name="objectType">
                <option value="">Выберите тип объекта</option>
                <option>Квартира</option>
                <option>Дом</option>
                <option>Коммерческое пространство</option>
              </select>
            </label>
            <label class="field">
              <span>Адрес объекта</span>
              <input name="address" placeholder="Город, улица, ЖК" />
            </label>
            <label class="field">
              <span>Площадь, м²*</span>
              <input required name="area" type="number" min="10" placeholder="Например, 92" />
            </label>
            <label class="field">
              <span>Количество комнат*</span>
              <select required name="rooms">
                <option value="">Выберите количество</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>
                <option>4+</option>
              </select>
            </label>
          </div>
        </section>

        <section class="form-section" aria-labelledby="preferences">
          <h2 id="preferences">3. Ваши предпочтения</h2>
          <fieldset class="form-group">
            <legend>Предпочитаемый стиль</legend>
            <div class="option-grid">
              {["Современный минимализм", "Неоклассика", "Современная классика", "Джапанди", "Скандинавский", "Лофт", "Wabi-sabi", "Эклектика", "Другое"].map((item) => (
                <label class="check-option"><input type="checkbox" name="style" value={item} /> {item}</label>
              ))}
            </div>
          </fieldset>
          <div class="form-grid">
            <label class="field">
              <span>Бюджет на реализацию*</span>
              <select required name="budget">
                <option value="">Выберите диапазон</option>
                <option>до 5 млн ₽</option>
                <option>5-10 млн ₽</option>
                <option>10-20 млн ₽</option>
                <option>20+ млн ₽</option>
              </select>
            </label>
            <label class="field">
              <span>Желаемые сроки реализации*</span>
              <select required name="deadline">
                <option value="">Выберите срок</option>
                <option>1-3 месяца</option>
                <option>3-6 месяцев</option>
                <option>6-12 месяцев</option>
                <option>Сроки гибкие</option>
              </select>
            </label>
          </div>
        </section>

        <section class="form-section" aria-labelledby="family">
          <h2 id="family">4. Состав семьи</h2>
          <div class="form-grid">
            <label class="field">
              <span>Кто будет жить в интерьере?</span>
              <select name="family">
                <option>Один человек</option>
                <option>Пара</option>
                <option>Семья с детьми</option>
                <option>Несколько поколений</option>
              </select>
            </label>
            <fieldset class="form-group">
              <legend>Есть ли дети или питомцы?</legend>
              <div class="option-grid">
                <label class="check-option"><input type="checkbox" name="children" /> Дети</label>
                <label class="check-option"><input type="checkbox" name="pets" /> Питомцы</label>
                <label class="check-option"><input type="checkbox" name="plans" /> Планируем</label>
                <label class="check-option"><input type="checkbox" name="none" /> Нет</label>
              </div>
            </fieldset>
          </div>
        </section>

        <section class="form-section" aria-labelledby="materials">
          <h2 id="materials">5. Пожелания по материалам и наполнению</h2>
          <fieldset class="form-group">
            <legend>Предпочтительные материалы</legend>
            <div class="option-grid">
              {["Дерево", "Камень", "Микроцемент", "Металл", "Стекло", "Текстиль", "Натуральные материалы", "Другое"].map((item) => (
                <label class="check-option"><input type="checkbox" name="materials" value={item} /> {item}</label>
              ))}
            </div>
          </fieldset>
          <fieldset class="form-group">
            <legend>Что важно в интерьере?</legend>
            <div class="option-grid">
              {["Функциональность", "Эстетика", "Хранение", "Простор и свет", "Уют и комфорт", "Другое"].map((item) => (
                <label class="check-option"><input type="checkbox" name="priorities" value={item} /> {item}</label>
              ))}
            </div>
          </fieldset>
        </section>

        <section class="form-section" aria-labelledby="rooms">
          <h2 id="rooms">6. Обязательные зоны и помещения</h2>
          <div class="option-grid">
            {["Прихожая", "Кухня", "Гостиная", "Спальня", "Детская", "Кабинет", "Гардеробная", "Санузел", "Постирочная", "Кладовая", "Балкон / лоджия", "Терраса"].map((item) => (
              <label class="check-option"><input type="checkbox" name="roomsList" value={item} /> {item}</label>
            ))}
          </div>
          <label class="field">
            <span>Другое помещение</span>
            <input name="otherRoom" placeholder="Укажите другое помещение" />
          </label>
        </section>

        <section class="form-section" aria-labelledby="references">
          <h2 id="references">7. Референсы</h2>
          <div class="form-grid">
            <label class="field">
              <span>Ссылки на вдохновение</span>
              <textarea name="links" placeholder="Pinterest, Instagram, Houzz или краткое описание"></textarea>
            </label>
            <label class="upload-zone">
              <CloudUpload size={28} stroke-width={1.4} />
              <span>Загрузите изображения, если они уже есть</span>
              <input type="file" name="files" multiple accept="image/*,.pdf" />
            </label>
          </div>
        </section>

        <section class="form-section" aria-labelledby="comments">
          <h2 id="comments">8. Дополнительные комментарии</h2>
          <label class="field">
            <span>Что еще важно учесть?</span>
            <textarea name="comments" placeholder="Ваш комментарий"></textarea>
          </label>
          <button class="button button-dark" type="submit">Отправить бриф</button>
          <p class="form-status" data-form-status aria-live="polite"></p>
          <p class="process-note"><Lock size={16} stroke-width={1.5} /> Мы ценим вашу конфиденциальность и не передаем данные третьим лицам.</p>
        </section>
      </form>

      <aside class="brief-sidebar" aria-label="Помощь по брифу">
        <div class="side-panel">
          <Clock3 size={30} stroke-width={1.4} />
          <h2>Сколько времени займет?</h2>
          <h3>10-15 минут</h3>
          <p>Ответьте в удобном темпе. Это поможет нам лучше понять задачу и предложить точное решение.</p>
        </div>
        <div class="side-panel">
          <h2>Почему важен бриф?</h2>
          <p><strong>Экономия времени.</strong> Четкая информация с самого начала ускоряет процесс.</p>
          <p><strong>Точность решений.</strong> Мы учитываем ваши пожелания и предлагаем релевантные идеи.</p>
          <p><strong>Прозрачность бюджета.</strong> Понимаем рамки и предлагаем оптимальные решения.</p>
        </div>
        <div class="side-panel">
          <img src={asset.kitchen} alt="Кухня-гостиная с натуральными материалами" loading="lazy" decoding="async" />
          <h3>Хороший дизайн начинается с правильных вопросов</h3>
          <p>Команда AURUM</p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
